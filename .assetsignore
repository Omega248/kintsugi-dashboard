# Exclude node_modules installed by wrangler-action at deploy time
node_modules/

# Exclude the Discord bot worker (deployed separately via deploy-bot.yml)
discord-bot/

# Exclude generated deploy-time file (never committed to the repo)
bot-config.js

# Exclude CI/CD configuration
.github/

# Exclude version-control metadata
.git/
.gitignore

# Exclude Wrangler configuration and cache
wrangler.jsonc
worker.js
.assetsignore
.wrangler/

# Exclude editor and OS artifacts
.vscode/
.idea/
.DS_Store
Thumbs.db

# Exclude logs
*.log
